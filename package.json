{
  "name": "secret-keeper-check",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "dotenvx run -f .env.example -- vite --config vite.config.ts",
    "frontend:build": "vite build --config vite.config.ts --emptyOutDir",
    "preview": "dotenvx run -f .env.production -- vite preview --port 5001",
    "env:decrypt": "dotenvx decrypt -f .env.production",
    "env:encrypt": "dotenvx encrypt -f .env.production"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "6.28.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.32.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "typescript": "5.2.2",
    "vite": "^5.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
